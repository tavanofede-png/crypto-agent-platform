# ─────────────────────────────────────────────────────────────────────────────
#  LOCAL DEVELOPMENT — copy this file to .env and fill in the blanks.
#  All values here are safe for local use; none should go to production.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker-managed local Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crypto_agents

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Dev-only secret — CHANGE THIS for any shared or production environment
JWT_SECRET=dev-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── LLM APIs ─────────────────────────────────────────────────────────────────
# At least one key is required to use the chat feature.
# Leave blank to get helpful errors when chat is attempted.
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─── Runtime (agent workspace service) ────────────────────────────────────────
RUNTIME_URL=http://localhost:3002
RUNTIME_PORT=3002
# Workspaces are created here — a temp dir is fine for local dev
WORKSPACE_BASE=/tmp/cap-workspaces

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
# Sepolia testnet is the dev default — matches ACTIVE_CHAINS below
NEXT_PUBLIC_CHAIN_ID=11155111
# Get a free project ID at https://cloud.walletconnect.com (optional for dev)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo-project-id

# ─── Credits / payments ───────────────────────────────────────────────────────
CREDITS_PER_DOLLAR=100
PAYMENT_MIN_AMOUNT=5.0
PAYMENT_SESSION_TTL_MINUTES=15

# ─── Mock payment mode ────────────────────────────────────────────────────────
# POST /api/payments/mock-confirm { "amount": 10 } → adds 1000 credits instantly.
# This endpoint is blocked when NODE_ENV=production.
# No RPC URL or treasury address needed for mock payments.
# Set ACTIVE_CHAINS to empty string to disable the blockchain watcher entirely
# (useful if you don't have an RPC key yet).
ACTIVE_CHAINS=

# ─── Blockchain watcher (leave empty for mock-only local dev) ─────────────────
# When ACTIVE_CHAINS is empty the watcher starts with zero chains — safe.
# Uncomment and fill in to test real on-chain detection with Sepolia:
#
# ACTIVE_CHAINS=11155111
# TREASURY_ADDRESS=0xYourLocalTreasuryWallet
# CHAIN_11155111_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# REQUIRED_CONFIRMATIONS_DEFAULT=1
# REQUIRED_CONFIRMATIONS_11155111=1
# CHAIN_11155111_TOKENS=

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
