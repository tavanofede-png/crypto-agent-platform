generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AgentStatus {
  PROVISIONING
  RUNNING
  STOPPED
  ERROR
  DELETED
}

enum AgentFramework {
  OPENCLAW
  ZEROCLAW
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum PaymentSessionStatus {
  PENDING      // Waiting for user to send payment
  DETECTED     // Transfer seen on-chain, awaiting confirmations
  CONFIRMING   // Has some confirmations, not yet enough
  CONFIRMED    // Required confirmations reached — credits/unlock applied
  EXPIRED      // Session TTL elapsed before payment arrived
  FAILED       // Payment detected but something went wrong processing it
}

enum PaymentPurpose {
  AGENT_CREATION
  CREDIT_TOPUP
}

// ─── Core models ─────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  walletAddress String        @unique @map("wallet_address")
  nonce         String        @default(cuid())
  credits       Int           @default(0)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  agents          Agent[]
  transactions    Transaction[]
  paymentSessions PaymentSession[]
  creditLedger    CreditLedger[]

  @@map("users")
}

model Agent {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  name          String
  description   String?
  framework     AgentFramework @default(ZEROCLAW)
  model         String         @default("gpt-4o")
  status        AgentStatus    @default(PROVISIONING)
  workspacePath String?        @map("workspace_path")
  systemPrompt  String?        @map("system_prompt") @db.Text
  temperature   Float          @default(0.7)
  maxTokens     Int            @default(2048) @map("max_tokens")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill         Skill?
  chatSessions  ChatSession[]
  logs          AgentLog[]

  @@index([userId])
  @@index([status])
  @@map("agents")
}

model Skill {
  id        String   @id @default(cuid())
  agentId   String   @unique @map("agent_id")
  content   String   @db.Text
  template  String?
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model ChatSession {
  id        String        @id @default(cuid())
  agentId   String        @map("agent_id")
  title     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([agentId])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String      @map("session_id")
  role         String
  content      String      @db.Text
  tokensUsed   Int?        @map("tokens_used")
  durationMs   Int?        @map("duration_ms")
  createdAt    DateTime    @default(now()) @map("created_at")

  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// Legacy simple transaction (mock payment, keep for compat)
model Transaction {
  id             String            @id @default(cuid())
  walletAddress  String            @map("wallet_address")
  txHash         String?           @unique @map("tx_hash")
  amount         Float
  token          String            @default("USDC")
  chainId        Int               @default(1) @map("chain_id")
  status         TransactionStatus @default(PENDING)
  creditsAwarded Int               @default(0) @map("credits_awarded")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user           User              @relation(fields: [walletAddress], references: [walletAddress])

  @@index([walletAddress])
  @@map("transactions")
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String   @map("agent_id")
  level     LogLevel @default(INFO)
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@map("agent_logs")
}

// ─── Blockchain payment models ───────────────────────────────────────────────

/// A payment intent created by the backend before the user sends crypto.
/// Matches a user to an incoming transfer via their authenticated walletAddress.
model PaymentSession {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  /// Wallet address of the authenticated user — used for transfer matching
  walletAddress  String               @map("wallet_address")
  chainId        Int                  @map("chain_id")
  /// null = native token (ETH/MATIC/etc), non-null = ERC-20 contract address
  tokenAddress   String?              @map("token_address")
  tokenSymbol    String               @map("token_symbol")
  tokenDecimals  Int                  @default(18) @map("token_decimals")
  /// Amount in the token's smallest unit (wei for ETH, 6-decimal unit for USDC)
  /// Stored as string to avoid bigint overflow in JSON
  expectedAmount String               @map("expected_amount")
  /// Human-readable display amount (e.g. "5.00")
  displayAmount  String               @map("display_amount")
  purpose        PaymentPurpose
  status         PaymentSessionStatus @default(PENDING)
  expiresAt      DateTime             @map("expires_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockchainPayment BlockchainPayment?

  @@index([walletAddress, chainId, status])
  @@index([status, expiresAt])
  @@map("payment_sessions")
}

/// On-chain payment record created when a matching transfer is detected.
model BlockchainPayment {
  id             String    @id @default(cuid())
  sessionId      String    @unique @map("session_id")
  txHash         String    @unique @map("tx_hash")
  blockNumber    Int       @map("block_number")
  chainId        Int       @map("chain_id")
  fromAddress    String    @map("from_address")
  toAddress      String    @map("to_address")
  /// null = native token transfer
  tokenAddress   String?   @map("token_address")
  /// Amount in smallest unit, stored as string
  amountReceived String    @map("amount_received")
  confirmations  Int       @default(0)
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  session        PaymentSession @relation(fields: [sessionId], references: [id])

  @@index([chainId, blockNumber])
  @@index([chainId, txHash])
  @@map("blockchain_payments")
}

/// Idempotency guard: one row per processed on-chain event.
/// Unique constraint on (chainId, txHash, logIndex) prevents double-processing.
/// logIndex is null for native ETH transfers (not log-based).
model ProcessedChainEvent {
  id          String   @id @default(cuid())
  chainId     Int      @map("chain_id")
  txHash      String   @map("tx_hash")
  /// Log index within the transaction; null for native transfers
  logIndex    Int?     @map("log_index")
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@unique([chainId, txHash, logIndex])
  @@index([chainId, txHash])
  @@map("processed_chain_events")
}

/// Immutable ledger of every credit change — debits (negative) and credits (positive).
model CreditLedger {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  /// Positive = credit added, negative = credit spent
  delta        Int
  balanceAfter Int      @map("balance_after")
  /// "payment_confirmed" | "agent_creation" | "admin_grant" | "refund"
  reason       String
  sessionId    String?  @map("session_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("credit_ledger")
}
