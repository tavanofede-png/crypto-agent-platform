generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AgentStatus {
  PROVISIONING
  RUNNING
  STOPPED
  ERROR
  DELETED
}

enum AgentFramework {
  OPENCLAW
  ZEROCLAW
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

/// Lifecycle of an agent-creation order, from form submission to live agent.
enum OrderStatus {
  AWAITING_PAYMENT   // Payment session created, waiting for transfer
  PAYMENT_DETECTED   // Transfer seen on-chain, awaiting confirmations
  PAYMENT_CONFIRMED  // Required confirmations reached
  PROVISIONING       // Agent workspace being set up
  COMPLETED          // Agent is live
  FAILED             // Something went wrong (see failedReason)
}

enum PaymentSessionStatus {
  PENDING      // Waiting for user to send payment
  DETECTED     // Transfer seen on-chain, awaiting confirmations
  CONFIRMING   // Has some confirmations, not yet enough
  CONFIRMED    // Required confirmations reached
  EXPIRED      // Session TTL elapsed before payment arrived
  FAILED       // Payment detected but something went wrong processing it
}

// ─── Core models ──────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique @map("wallet_address")
  nonce         String   @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agents              Agent[]
  agentCreationOrders AgentCreationOrder[]
  paymentSessions     PaymentSession[]

  @@map("users")
}

model Agent {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  name          String
  description   String?
  framework     AgentFramework @default(ZEROCLAW)
  model         String         @default("gpt-4o")
  status        AgentStatus    @default(PROVISIONING)
  workspacePath String?        @map("workspace_path")
  systemPrompt  String?        @map("system_prompt") @db.Text
  temperature   Float          @default(0.7)
  maxTokens     Int            @default(2048) @map("max_tokens")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill         Skill?
  chatSessions  ChatSession[]
  logs          AgentLog[]
  creationOrder AgentCreationOrder?

  @@index([userId])
  @@index([status])
  @@map("agents")
}

model Skill {
  id        String   @id @default(cuid())
  agentId   String   @unique @map("agent_id")
  content   String   @db.Text
  template  String?
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model ChatSession {
  id        String        @id @default(cuid())
  agentId   String        @map("agent_id")
  title     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([agentId])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String      @map("session_id")
  role         String
  content      String      @db.Text
  tokensUsed   Int?        @map("tokens_used")
  durationMs   Int?        @map("duration_ms")
  createdAt    DateTime    @default(now()) @map("created_at")

  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String   @map("agent_id")
  level     LogLevel @default(INFO)
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@map("agent_logs")
}

// ─── Agent Creation Orders ────────────────────────────────────────────────────

/// Central entity for the create-agent flow.
/// Holds the agent config snapshot + tracks payment lifecycle.
model AgentCreationOrder {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  status        OrderStatus    @default(AWAITING_PAYMENT)

  // Agent config — stored so the agent can be provisioned after payment
  agentName     String         @map("agent_name")
  agentDescr    String?        @db.Text @map("agent_description")
  framework     AgentFramework
  model         String
  skillTemplate String         @map("skill_template")
  skillContent  String         @db.Text @map("skill_content")
  temperature   Float          @default(0.7)
  maxTokens     Int            @default(2048) @map("max_tokens")

  // Pricing snapshot at order creation time
  priceAmount   String         @map("price_amount")   // human-readable, e.g. "5.00"
  priceToken    String         @map("price_token")    // e.g. "ETH" or "USDC"
  priceChainId  Int            @map("price_chain_id")

  // Outcome
  agentId       String?        @unique @map("agent_id")
  txHash        String?        @map("tx_hash")
  failedReason  String?        @map("failed_reason")

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent         Agent?         @relation(fields: [agentId], references: [id])
  paymentSession PaymentSession?

  @@index([userId])
  @@index([status])
  @@map("agent_creation_orders")
}

// ─── Blockchain payment models ────────────────────────────────────────────────

/// A payment intent created before the user sends crypto.
model PaymentSession {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  walletAddress  String               @map("wallet_address")
  chainId        Int                  @map("chain_id")
  tokenAddress   String?              @map("token_address")
  tokenSymbol    String               @map("token_symbol")
  tokenDecimals  Int                  @default(18) @map("token_decimals")
  expectedAmount String               @map("expected_amount")
  displayAmount  String               @map("display_amount")
  status         PaymentSessionStatus @default(PENDING)
  expiresAt      DateTime             @map("expires_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  // Link to the order this session is paying for
  orderId        String?              @unique @map("order_id")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  order             AgentCreationOrder? @relation(fields: [orderId], references: [id])
  blockchainPayment BlockchainPayment?

  @@index([walletAddress, chainId, status])
  @@index([status, expiresAt])
  @@map("payment_sessions")
}

/// On-chain payment record created when a matching transfer is detected.
model BlockchainPayment {
  id             String    @id @default(cuid())
  sessionId      String    @unique @map("session_id")
  txHash         String    @unique @map("tx_hash")
  blockNumber    Int       @map("block_number")
  chainId        Int       @map("chain_id")
  fromAddress    String    @map("from_address")
  toAddress      String    @map("to_address")
  tokenAddress   String?   @map("token_address")
  amountReceived String    @map("amount_received")
  confirmations  Int       @default(0)
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  session        PaymentSession @relation(fields: [sessionId], references: [id])

  @@index([chainId, blockNumber])
  @@index([chainId, txHash])
  @@map("blockchain_payments")
}

/// Idempotency guard: prevents double-processing the same on-chain event.
model ProcessedChainEvent {
  id          String   @id @default(cuid())
  chainId     Int      @map("chain_id")
  txHash      String   @map("tx_hash")
  logIndex    Int?     @map("log_index")
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@unique([chainId, txHash, logIndex])
  @@index([chainId, txHash])
  @@map("processed_chain_events")
}
