# Copiar a variables en Railway (valores de ejemplo; ajustar por servicio)

# ─── Compartidas (api + worker) ─────────────────────────────
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# ─── API ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
NONCE_TTL_MINUTES=10
FRONTEND_URL=https://your-web.up.railway.app
RUNTIME_URL=http://runtime.railway.internal:3002

# ─── Web (marcar "build time" en Railway) ───────────────────
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
NEXT_PUBLIC_WS_URL=wss://your-api.up.railway.app
NEXT_PUBLIC_CHAIN_ID=11155111

# ─── Runtime ────────────────────────────────────────────────
OPENAI_API_KEY=
RUNTIME_PORT=3002
WORKSPACE_BASE=/tmp/cap-workspaces
