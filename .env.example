# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crypto_agents

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── LLM APIs ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Runtime Service ───────────────────────────────────────
RUNTIME_URL=http://localhost:3002
RUNTIME_PORT=3002
WORKSPACE_BASE=/tmp/workspaces

# ─── API ───────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_CHAIN_ID=1

# ─── Payment (MVP) ─────────────────────────────────────────
PAYMENT_RECIPIENT_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e
PAYMENT_MIN_AMOUNT=5.0
PAYMENT_TOKEN=USDC
CREDITS_PER_DOLLAR=100

# ─── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60
