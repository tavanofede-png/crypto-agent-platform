# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crypto_agents

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── LLM APIs ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Runtime Service ───────────────────────────────────────
RUNTIME_URL=http://localhost:3002
RUNTIME_PORT=3002
WORKSPACE_BASE=/tmp/workspaces

# ─── API ───────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
# Default to Sepolia testnet for local dev; change to 1 for mainnet production
NEXT_PUBLIC_CHAIN_ID=11155111

# ─── Agent creation pricing ────────────────────────────────
# How much a user pays to create one agent.
AGENT_CREATION_PRICE=0.005
AGENT_CREATION_CHAIN_ID=11155111
AGENT_CREATION_TOKEN_ADDRESS=
AGENT_CREATION_TOKEN_SYMBOL=ETH
AGENT_CREATION_TOKEN_DECIMALS=18

# ─── Payment session ───────────────────────────────────────
PAYMENT_SESSION_TTL_MINUTES=15

# ─── Treasury wallet ───────────────────────────────────────
# The address that receives all crypto payments from users.
TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# ─── Blockchain: active chains (comma-separated chain IDs) ─
# Use 11155111 (Sepolia testnet) for local dev.
# Set to empty string to disable the watcher and rely on mock payments only.
# Empty = no RPC required; payment watcher idle. Add chain IDs + CHAIN_<id>_RPC_URL to enable.
ACTIVE_CHAINS=

# ─── Per-chain RPC URLs (required for each ACTIVE_CHAIN) ───
# Get free endpoints from Alchemy (alchemy.com) or Infura
CHAIN_1_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_137_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_42161_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_8453_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_11155111_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Block confirmations per chain ─────────────────────────
REQUIRED_CONFIRMATIONS_DEFAULT=2
REQUIRED_CONFIRMATIONS_1=12
REQUIRED_CONFIRMATIONS_137=64
REQUIRED_CONFIRMATIONS_42161=2
REQUIRED_CONFIRMATIONS_8453=2
REQUIRED_CONFIRMATIONS_11155111=1

# ─── ERC-20 tokens per chain (SYMBOL:address:decimals,...) ─
CHAIN_1_TOKENS=USDC:0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48:6,USDT:0xdAC17F958D2ee523a2206206994597C13D831ec7:6
CHAIN_137_TOKENS=USDC:0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174:6,USDT:0xc2132D05D31c914a87C6611C10748AEb04B58e8F:6
CHAIN_42161_TOKENS=USDC:0xaf88d065e77c8cC2239327C5EDb3A432268e5831:6,USDT:0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9:6
CHAIN_8453_TOKENS=USDC:0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913:6
CHAIN_11155111_TOKENS=
CHAIN_80002_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
REQUIRED_CONFIRMATIONS_80002=1
CHAIN_80002_TOKENS=

# ─── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60
