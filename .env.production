# ════════════════════════════════════════════════════════════
#  PRODUCTION ENVIRONMENT — copy this to /opt/cap/.env on VPS
#  NEVER commit the actual .env to git
# ════════════════════════════════════════════════════════════

# ─── Domain ──────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=cap_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_32chars
POSTGRES_DB=crypto_agents

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_32chars

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ─── LLM APIs ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Payment ─────────────────────────────────────────────────
PAYMENT_RECIPIENT_ADDRESS=0xYourWalletAddress
PAYMENT_MIN_AMOUNT=5
CREDITS_PER_DOLLAR=100

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_CHAIN_ID=1

# ─── Docker image registry ───────────────────────────────────
REGISTRY=ghcr.io
REPO_OWNER=tavanofede-png
IMAGE_TAG=latest
