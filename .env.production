# ════════════════════════════════════════════════════════════
#  PRODUCTION ENVIRONMENT — copy this to /opt/cap/.env on VPS
#  NEVER commit this file to git
# ════════════════════════════════════════════════════════════

# ─── Domain ──────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=cap_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_32chars
POSTGRES_DB=crypto_agents

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_32chars

# ─── JWT ─────────────────────────────────────────────────────
# Generate BOTH with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_different
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Auth nonce ───────────────────────────────────────────────
# How long the sign challenge remains valid before expiring.
NONCE_TTL_MINUTES=10

# ─── LLM APIs ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Agent creation pricing ──────────────────────────────────
# These must match what the frontend shows and what the watcher expects.
AGENT_CREATION_PRICE=0.005
AGENT_CREATION_CHAIN_ID=11155111
AGENT_CREATION_TOKEN_ADDRESS=
AGENT_CREATION_TOKEN_SYMBOL=ETH
AGENT_CREATION_TOKEN_DECIMALS=18

# ─── Payment session ─────────────────────────────────────────
PAYMENT_SESSION_TTL_MINUTES=15

# ─── Treasury wallet ─────────────────────────────────────────
# The wallet address that receives payments from users.
TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# ─── Blockchain watcher ──────────────────────────────────────
# Comma-separated chain IDs to watch. Leave empty to disable.
ACTIVE_CHAINS=11155111

# Sepolia (testnet) — swap for mainnet chain IDs in prod
CHAIN_11155111_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
REQUIRED_CONFIRMATIONS_DEFAULT=2
REQUIRED_CONFIRMATIONS_11155111=1

# ERC-20 tokens to watch per chain (optional for ETH-only payments)
# Format: SYMBOL:address:decimals  (comma-separated for multiple tokens)
CHAIN_11155111_TOKENS=

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_CHAIN_ID=11155111

# ─── Docker image registry ───────────────────────────────────
REGISTRY=ghcr.io
REPO_OWNER=tavanofede-png
IMAGE_TAG=latest
